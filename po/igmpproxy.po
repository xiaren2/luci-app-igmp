msgid "IGMPPROXY设置"
msgstr "IGMPPROXY Settings"

msgid "配置IGMPPROXY以实现组播转发，igmpproxy仅支持ipv4。"
msgstr "Configure IGMPPROXY for multicast forwarding. igmpproxy only supports IPv4."

msgid "常规设置"
msgstr "General Settings"

msgid "快速离开"
msgstr "Quick Leave"

msgid "启用快速离开功能，减少离开延迟"
msgstr "Enable quick leave function to reduce leave latency"

msgid "日志级别"
msgstr "Log Level"

msgid "无"
msgstr "None"

msgid "最小"
msgstr "Minimal"

msgid "中等"
msgstr "Medium"

msgid "详细"
msgstr "Verbose"

msgid "设置日志输出的详细程度"
msgstr "Set the verbosity of log output"

msgid "接口配置"
msgstr "Interface Configuration"

msgid "方向"
msgstr "Direction"

msgid "上行 (连接到组播来源)"
msgstr "Upstream (Connect to multicast source)"

msgid "下行 (连接到接收设备)"
msgstr "Downstream (Connect to receiving devices)"

msgid "禁用 (不参与组播)"
msgstr "Disabled (Not participating in multicast)"

msgid "设置接口的组播流向方向"
msgstr "Set the multicast flow direction for the interface"

msgid "网络接口"
msgstr "Network Interface"

msgid "选择要配置的网络接口（优先别名），或选择自定义输入"
msgstr "Select the network interface to configure (prefer aliases), or choose custom input"

msgid "防火墙区域"
msgstr "Firewall Zone"

msgid "选择要配置的防火墙区域"
msgstr "Select the firewall zone to configure"

msgid "放行网络段"
msgstr "Allowed Network Segments"

msgid "例如: 10.0.0.0/8"
msgstr "e.g., 10.0.0.0/8"

msgid "仅对上行接口有效。可以添加多个组播地址/中转范围。"
msgstr "Only valid for upstream interfaces. Can add multiple multicast addresses/relay ranges."

msgid "-- 请选择接口 --"
msgstr "-- Please select interface --"
