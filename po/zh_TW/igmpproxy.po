msgid "IGMPPROXY设置"
msgstr "IGMPPROXY 設定"

msgid "配置IGMPPROXY以实现组播转发，igmpproxy仅支持ipv4。"
msgstr "設定 IGMPPROXY 以實現群播轉發，igmpproxy 僅支援 IPv4。"

msgid "常规设置"
msgstr "常規設定"

msgid "快速离开"
msgstr "快速離開"

msgid "启用快速离开功能，减少离开延迟"
msgstr "啟用快速離開功能，減少離開延遲"

msgid "日志级别"
msgstr "日誌級別"

msgid "无"
msgstr "無"

msgid "最小"
msgstr "最小"

msgid "中等"
msgstr "中等"

msgid "详细"
msgstr "詳細"

msgid "设置日志输出的详细程度"
msgstr "設定日誌輸出的詳細程度"

msgid "接口配置"
msgstr "介面配置"

msgid "接口配置请自行选择，并观察etc/igmpproxy.conf是否生成了配置的那行。一般是选取别名配置，例如br-lan选择lan,那么igmpproxy.conf生成的就是br-lan,如果你直接选br-lan可能会无法在igmpproxy.conf生成配置行，说明选取有误。防火墙不选择可能会无法播放，请自行测试。通过观察 igmpproxy 日志来决定放行的 IP 段，并不一定是组播 IP 段。如不会查看请放行0.0.0.0/0"
msgstr "介面配置請自行選擇，並觀察 etc/igmpproxy.conf 是否產生了設定的那一行。一般是選取別名設定，例如 br-lan 選擇 lan，那麼 igmpproxy.conf 產生的就是 br-lan，如果你直接選 br-lan 可能會無法在 igmpproxy.conf 產生設定行，說明選取有誤。防火牆不選擇可能會無法播放，請自行測試。透過觀察 igmpproxy 日誌來決定放行的 IP 段，並不一定是群播 IP 段。如不會查看請放行 0.0.0.0/0"

msgid "方向"
msgstr "方向"

msgid "上行 (连接到组播来源)"
msgstr "上行 (連接到群播來源)"

msgid "下行 (连接到接收设备)"
msgstr "下行 (連接到接收設備)"

msgid "禁用 (不参与组播)"
msgstr "禁用 (不參與群播)"

msgid "设置接口的组播流向方向"
msgstr "設定介面的群播流向方向"

msgid "网络接口"
msgstr "網路介面"

msgid "选择要配置的网络接口（优先别名），或选择自定义输入"
msgstr "選擇要設定的網路介面（優先別名），或選擇自訂輸入"

msgid "防火墙区域"
msgstr "防火牆區域"

msgid "选择要配置的防火墙区域"
msgstr "選擇要設定的防火牆區域"

msgid "放行网络段"
msgstr "放行網路段"

msgid "例如: 10.0.0.0/8"
msgstr "例如: 10.0.0.0/8"

msgid "仅对上行接口有效。可以添加多个组播地址/中转范围。"
msgstr "僅對上行介面有效。可以新增多個群播地址/中轉範圍。"

msgid "-- 请选择接口 --"
msgstr "-- 請選擇介面 --"

msgid "回环: %s"
msgstr "迴環: %s"

msgid "网桥: %s"
msgstr "網橋: %s"

msgid "以太网: %s"
msgstr "乙太網路: %s"

msgid "无线: %s"
msgstr "無線: %s"

msgid "隧道: %s"
msgstr "隧道: %s"

msgid "PPP: %s"
msgstr "PPP: %s"

msgid "USB: %s"
msgstr "USB: %s"

msgid "VLAN: %s"
msgstr "VLAN: %s"

msgid "GRE: %s"
msgstr "GRE: %s"

msgid "网络: %s"
msgstr "網路: %s"

msgid "别名: %s (%s)"
msgstr "別名: %s (%s)"
